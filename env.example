# ============================================================
# Megan Bot — متغيرات البيئة
# ============================================================
# انسخ هذا الملف كـ .env (محلياً) أو أضف القيم في Railway Dashboard
# لا ترفع ملف .env الحقيقي إلى GitHub!

# 🔴 توكن Megan Bot (إجباري)
MEGAN_TOKEN=your_discord_bot_token_here

# 🖼️ رابط الـ banner (اختياري — لو محدد، يستخدم بدل الصورة المحلية)
# لو تركته فارغ، البوت سيرفع megan-assets/banner.png تلقائياً
MEGAN_BANNER_URL=

# 👑 ID مالك البوت (اختياري — الافتراضي مضبوط في الكود)
# BOT_OWNER_ID=1077949215772250143
